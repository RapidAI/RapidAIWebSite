---
import "../styles/global.css";
import { footerBrand, footerColumns, navItems } from "../data/site";
import { withBase } from "../utils/base";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description = "RapidAI 是一个专注 AI 工程化落地的开源组织。",
  image = "/images/RapidAIv6.png",
  type = "website",
  noindex = false
} = Astro.props;
const pathname = Astro.url.pathname;
const normalizePath = (value: string) => {
  if (!value) return "/";
  return value.length > 1 ? value.replace(/\/+$/, "") : value;
};
const homeHref = withBase("/");
const normalizedPathname = normalizePath(pathname);
const isHome = normalizedPathname === normalizePath(homeHref);
const siteUrl = Astro.site ?? new URL("https://rapidai.org");
const canonical = new URL(pathname, siteUrl).toString();
const resolvedImage = /^(https?:)?\/\//.test(image) ? image : new URL(withBase(image), siteUrl).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#06111f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f4f8ff" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="dark light" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={withBase("/images/RapidAIv6.png")} />
    <meta property="og:site_name" content="RapidAI" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={resolvedImage} />
    <meta property="og:image:alt" content="RapidAI" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedImage} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const storageKey = "rapidai-theme";
        const themeDefaultVersionKey = "rapidai-theme-default-version";
        const themeDefaultVersion = "2026-04-23-system";
        const root = document.documentElement;
        const currentThemeDefaultVersion = window.localStorage.getItem(themeDefaultVersionKey);

        if (currentThemeDefaultVersion !== themeDefaultVersion) {
          window.localStorage.removeItem(storageKey);
          window.localStorage.setItem(themeDefaultVersionKey, themeDefaultVersion);
        }

        const stored = window.localStorage.getItem(storageKey);
        const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const mode = stored === "light" || stored === "dark" || stored === "system" ? stored : "system";
        const theme = mode === "system" ? (systemPrefersDark ? "dark" : "light") : mode;
        root.dataset.themeMode = mode;
        root.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <div class:list={["site-shell", isHome && "site-shell-home"]}>
      <div class="bg-orb bg-orb-left"></div>
      <div class="bg-orb bg-orb-right"></div>
      <header class="site-header">
        <a class="brand" href={homeHref}>
          <img src={withBase("/images/RapidAIv6.png")} alt="RapidAI" />
          <span>RapidAI</span>
        </a>
        <div class="site-header-actions">
          <nav id="site-nav" class="site-nav" aria-label="主导航">
            {
              navItems.map((item) => (
                <a class={normalizedPathname === normalizePath(withBase(item.href)) ? "active" : ""} href={withBase(item.href)}>
                  {item.label}
                </a>
              ))
            }
          </nav>
          <button class="theme-toggle" type="button" aria-label="切换主题模式">
            <span class="theme-toggle-icon" aria-hidden="true">◐</span>
            <span class="theme-toggle-label">跟随系统</span>
          </button>
        </div>
        <button
          class="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="打开导航菜单"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-brand">
          <p>{footerBrand.name}</p>
          <p>{footerBrand.description}</p>
          <p class="footer-meta">{footerBrand.meta}</p>
        </div>
        <div class="footer-columns">
          {
            footerColumns.map((column) => (
              <div class="footer-column">
                <span>{column.title}</span>
                {column.links.map((link) => (
                  <a
                    href={link.external ? link.href : withBase(link.href)}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            ))
          }
        </div>
      </footer>
    </div>
    <script is:inline>
      const applyMemberNewBadges = () => {
        const today = new Date();
        today.setHours(0, 0, 0, 0);

        for (const node of document.querySelectorAll("[data-member-new-until], [data-member-joined-at]")) {
          const explicitUntil = node.getAttribute("data-member-new-until");
          const joinedAt = node.getAttribute("data-member-joined-at");
          let expiry = null;

          if (explicitUntil) {
            expiry = new Date(`${explicitUntil}T23:59:59`);
          } else if (joinedAt) {
            expiry = new Date(`${joinedAt}T23:59:59`);
            if (!Number.isNaN(expiry.getTime())) {
              expiry.setDate(expiry.getDate() + 2);
            }
          }

          if (!expiry) {
            continue;
          }

          if (Number.isNaN(expiry.getTime()) || expiry < today) {
            node.remove();
          }
        }
      };

      const setupMobileNav = () => {
        const header = document.querySelector(".site-header");
        const toggle = document.querySelector(".nav-toggle");
        const nav = document.querySelector("#site-nav");
        const shell = document.querySelector(".site-shell");
        const mobileQuery = window.matchMedia("(max-width: 820px)");

        if (
          !(header instanceof HTMLElement) ||
          !(toggle instanceof HTMLButtonElement) ||
          !(nav instanceof HTMLElement) ||
          !(shell instanceof HTMLElement)
        ) {
          return;
        }

        const closeMenu = () => {
          header.classList.remove("nav-open");
          shell.classList.remove("nav-overlay-visible");
          document.body.classList.remove("nav-lock");
          toggle.setAttribute("aria-expanded", "false");
        };

        const openMenu = () => {
          header.classList.add("nav-open");
          shell.classList.add("nav-overlay-visible");
          document.body.classList.add("nav-lock");
          toggle.setAttribute("aria-expanded", "true");
        };

        const syncMenuMode = () => {
          if (!mobileQuery.matches) {
            closeMenu();
          }
        };

        toggle.addEventListener("click", () => {
          const nextOpen = !header.classList.contains("nav-open");
          if (nextOpen) {
            openMenu();
          } else {
            closeMenu();
          }
        });

        nav.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            if (mobileQuery.matches) {
              closeMenu();
            }
          });
        });

        document.addEventListener("click", (event) => {
          if (!mobileQuery.matches || !header.classList.contains("nav-open")) {
            return;
          }

          if (event.target instanceof Node && !header.contains(event.target)) {
            closeMenu();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && header.classList.contains("nav-open")) {
            closeMenu();
            toggle.focus();
          }
        });

        syncMenuMode();
        mobileQuery.addEventListener("change", syncMenuMode);
      };

      const setupThemeToggle = () => {
        const root = document.documentElement;
        const button = document.querySelector(".theme-toggle");
        const label = document.querySelector(".theme-toggle-label");
        const storageKey = "rapidai-theme";
        const themeDefaultVersionKey = "rapidai-theme-default-version";
        const themeDefaultVersion = "2026-04-23-system";
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const modes = ["system", "dark", "light"];
        const modeLabels = {
          system: "跟随系统",
          dark: "深色",
          light: "浅色"
        };

        if (!(button instanceof HTMLButtonElement) || !(label instanceof HTMLElement)) {
          return;
        }

        if (window.localStorage.getItem(themeDefaultVersionKey) !== themeDefaultVersion) {
          window.localStorage.removeItem(storageKey);
          window.localStorage.setItem(themeDefaultVersionKey, themeDefaultVersion);
          root.dataset.themeMode = "system";
        }

        const resolveTheme = (mode) => mode === "system" ? (media.matches ? "dark" : "light") : mode;

        const getMode = () => {
          const mode = root.dataset.themeMode;
          return mode === "dark" || mode === "light" || mode === "system" ? mode : "system";
        };

        const applyMode = (mode, persist) => {
          root.dataset.themeMode = mode;
          root.dataset.theme = resolveTheme(mode);

          if (persist) {
            window.localStorage.setItem(storageKey, mode);
          }

          label.textContent = modeLabels[mode];

          const currentIndex = modes.indexOf(mode);
          const nextMode = modes[(currentIndex + 1) % modes.length];
          button.setAttribute("aria-label", `当前为${modeLabels[mode]}，点击切换到${modeLabels[nextMode]}`);
        };

        button.addEventListener("click", () => {
          const currentMode = getMode();
          const nextMode = modes[(modes.indexOf(currentMode) + 1) % modes.length];
          applyMode(nextMode, true);
        });

        media.addEventListener("change", () => {
          if (getMode() !== "system") {
            return;
          }
          applyMode("system", false);
        });

        applyMode(getMode(), false);
      };

      if (document.readyState === "loading") {
        document.addEventListener(
          "DOMContentLoaded",
          () => {
            applyMemberNewBadges();
            setupMobileNav();
            setupThemeToggle();
          },
          { once: true }
        );
      } else {
        applyMemberNewBadges();
        setupMobileNav();
        setupThemeToggle();
      }
    </script>
  </body>
</html>
