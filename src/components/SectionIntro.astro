---
import type { SectionIntroData } from "../types/site";

interface Props extends SectionIntroData {}

const { eyebrow, title, description, className = "" } = Astro.props;
---

<div class:list={["section-intro", className]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2>{title}</h2>
  <p>{description}</p>
</div>
