---
import { withBase } from "../utils/base";

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;
const prevHref = withBase(currentPage === 2 ? baseUrl : `${baseUrl}/page/${currentPage - 1}`);
const nextHref = withBase(`${baseUrl}/page/${currentPage + 1}`);
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="分页导航">
      {currentPage > 1 ? (
        <a class="button button-secondary pagination-link" href={prevHref}>
          上一页
        </a>
      ) : (
        <span class="button button-secondary pagination-link is-disabled">上一页</span>
      )}
      <span class="pagination-state">
        第 {currentPage} / {totalPages} 页
      </span>
      {currentPage < totalPages ? (
        <a class="button button-secondary pagination-link" href={nextHref}>
          下一页
        </a>
      ) : (
        <span class="button button-secondary pagination-link is-disabled">下一页</span>
      )}
    </nav>
  )
}
