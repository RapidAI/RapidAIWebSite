---
import type { DetailListCardData } from "../types/site";

interface Props {
  items: DetailListCardData[];
  className?: string;
}

const { items, className = "" } = Astro.props;
---

<div class:list={["card-grid", className]}>
  {
    items.map((card) => (
      <article class="card">
        <span class="card-tag">{card.tag}</span>
        <h3>{card.title}</h3>
        {card.description && <p>{card.description}</p>}
        {card.items && (
          <ul class="research-list">
            {card.items.map((item) => <li>{item}</li>)}
          </ul>
        )}
        {card.href && (
          <div class="card-meta">
            <span>{card.meta}</span>
            <a class="card-link" href={card.href}>
              {card.actionLabel || "查看详情"}
            </a>
          </div>
        )}
      </article>
    ))
  }
</div>
