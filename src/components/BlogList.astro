---
import { withBase } from "../utils/base";

interface PostEntry {
  id: string;
  data: {
    title: string;
    description: string;
    date: Date;
    author: string;
    tags: string[];
    cover: string;
    coverDark?: string;
  };
}

interface Props {
  posts: PostEntry[];
}

const { posts } = Astro.props;
---

<div class="blog-grid">
  {
    posts.map((post) => (
      <article class="card blog-card blog-card-compact">
        <div class="blog-card-body">
          <div class="blog-meta-row">
            <span class="timeline-label">{post.data.date.toISOString().slice(0, 10)}</span>
            <span class="blog-author">{post.data.author}</span>
          </div>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <div class="chip-row">
            {post.data.tags.map((tag) => <span class="chip">{tag}</span>)}
          </div>
          <div class="card-meta">
            <span>博客文章</span>
            <a class="card-link" href={withBase(`/blog/${post.id}`)}>阅读全文</a>
          </div>
        </div>
      </article>
    ))
  }
</div>
