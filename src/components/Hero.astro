---
import type { HomeHeroData } from "../types/site";
import { withBase } from "../utils/base";

interface Props {
  hero: HomeHeroData;
}

const { hero } = Astro.props;
---

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">{hero.eyebrow}</p>
    <h1>{hero.title}</h1>
    <p class="hero-description">{hero.description}</p>
    <div class="hero-actions">
      <a class="button button-primary" href={withBase(hero.primaryAction.href)}>
        {hero.primaryAction.label}
      </a>
      <a class="button button-secondary" href={withBase(hero.secondaryAction.href)}>
        {hero.secondaryAction.label}
      </a>
    </div>
    <div class="hero-badges">
      {hero.badges.map((badge) => <span>{badge}</span>)}
    </div>
  </div>
  <div class="hero-panel">
    <div class="panel-grid">
      {
        hero.panels.map((panel) => (
          <div class:list={["mini-card", panel.accent && "mini-card-strong", panel.wide && "mini-card-wide"]}>
            <span>{panel.tag}</span>
            <strong>{panel.title}</strong>
          </div>
        ))
      }
    </div>
    <div class="hero-panel-foot">
      <p>{hero.panelFoot}</p>
    </div>
  </div>
</section>
