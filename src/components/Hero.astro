---
import { withBase } from "../utils/base";

interface HeroPanel {
  tag: string;
  title: string;
  accent?: boolean;
  wide?: boolean;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryActionLabel: string;
  primaryActionHref: string;
  secondaryActionLabel: string;
  secondaryActionHref: string;
  badges: string[];
  panels: HeroPanel[];
  panelFoot: string;
}

const {
  eyebrow,
  title,
  description,
  primaryActionLabel,
  primaryActionHref,
  secondaryActionLabel,
  secondaryActionHref,
  badges,
  panels,
  panelFoot
} = Astro.props;
---

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="hero-description">{description}</p>
    <div class="hero-actions">
      <a class="button button-primary" href={withBase(primaryActionHref)}>{primaryActionLabel}</a>
      <a class="button button-secondary" href={withBase(secondaryActionHref)}>{secondaryActionLabel}</a>
    </div>
    <div class="hero-badges">
      {badges.map((badge) => <span>{badge}</span>)}
    </div>
  </div>
  <div class="hero-panel">
    <div class="panel-grid">
      {
        panels.map((panel) => (
          <div class:list={["mini-card", panel.accent && "mini-card-strong", panel.wide && "mini-card-wide"]}>
            <span>{panel.tag}</span>
            <strong>{panel.title}</strong>
          </div>
        ))
      }
    </div>
    <div class="hero-panel-foot">
      <p>{panelFoot}</p>
    </div>
  </div>
</section>
