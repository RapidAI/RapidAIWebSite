---
import ContentCardGrid from "../components/ContentCardGrid.astro";
import DynamicMembersGrid from "../components/DynamicMembersGrid.astro";
import PageHero from "../components/PageHero.astro";
import MainLayout from "../layouts/MainLayout.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { joinCards, membersPageHero, membersSections } from "../data/community";
import { memberGroups, memberRoleLabels, members } from "../data/members";
import { sectionsByKey } from "../data/sections";

const groupedMembers = memberGroups
  .map((group) => ({
    ...group,
    members: members
      .filter((member) => group.roles.includes(member.role))
      .map((member) => ({
        ...member,
        roleLabel: memberRoleLabels[member.role] || member.role
      }))
  }))
  .filter((group) => group.members.length > 0);

const uncategorizedMembers = members
  .filter((member) => !memberGroups.some((group) => group.roles.includes(member.role)))
  .map((member) => ({
    ...member,
    roleLabel: memberRoleLabels[member.role] || member.role
  }));
---

<MainLayout
  title={sectionsByKey.members.pageTitle}
  description={sectionsByKey.members.pageDescription}
>
  <PageHero
    eyebrow={membersPageHero.eyebrow}
    title={membersPageHero.title}
    description={membersPageHero.description}
    themeClass="page-hero-members"
    panel={membersPageHero.panel}
  />

  <section class="content-section">
    <SectionIntro
      eyebrow={membersSections.directory.eyebrow}
      title={membersSections.directory.title}
      description={membersSections.directory.description}
    />
    <div class="member-groups">
      {
        groupedMembers.map((group) => (
          <section class="member-group-section">
            <div class="member-group-head">
              <span class="card-tag">{group.members.length} 人</span>
              <h3>{group.title}</h3>
              <p>{group.description}</p>
            </div>
            <DynamicMembersGrid members={group.members} />
          </section>
        ))
      }
      {
        uncategorizedMembers.length > 0 && (
          <section class="member-group-section">
            <div class="member-group-head">
              <span class="card-tag">{uncategorizedMembers.length} 人</span>
              <h3>其他成员</h3>
              <p>未被分配到固定角色组的成员会展示在这里。</p>
            </div>
            <DynamicMembersGrid members={uncategorizedMembers} />
          </section>
        )
      }
    </div>
  </section>

  <section class="content-section">
    <SectionIntro
      eyebrow={membersSections.join.eyebrow}
      title={membersSections.join.title}
      description={membersSections.join.description}
    />
    <ContentCardGrid items={joinCards} className="join-card-grid" itemClassName="join-card" />
  </section>
</MainLayout>
