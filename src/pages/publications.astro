---
import PageHero from "../components/PageHero.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { publicationsRedirectPage } from "../data/publications";
import { withBase } from "../utils/base";

const target = withBase("/research#research-publications");
---

<MainLayout title="论文与成果 | RapidAI" description="跳转到研究院页面中的论文与成果部分。">
  <meta http-equiv="refresh" content={`0;url=${target}`} />
  <PageHero
    eyebrow={publicationsRedirectPage.eyebrow}
    title={publicationsRedirectPage.title}
    description={publicationsRedirectPage.description}
    themeClass="page-hero-publications"
  />
  <section class="content-section">
    <div class="section-actions">
      <a class="button button-primary" href={target}>{publicationsRedirectPage.actionLabel}</a>
    </div>
  </section>
</MainLayout>
