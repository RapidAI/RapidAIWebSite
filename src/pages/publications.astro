---
import { getCollection } from "astro:content";
import PageHero from "../components/PageHero.astro";
import PublicationCards from "../components/PublicationCards.astro";
import SectionIntro from "../components/SectionIntro.astro";
import MainLayout from "../layouts/MainLayout.astro";
import {
  publicationsPageActionLabel,
  publicationsPageHero,
  publicationsSectionIntro
} from "../data/publications";
import { sectionsByKey } from "../data/sections";
import { orderContentEntriesByFile } from "../utils/content-order";
import { withBase } from "../utils/base";

const publicationEntries = orderContentEntriesByFile(await getCollection("publications"));
const publications = publicationEntries.map((entry) => ({
  ...entry.data,
  detailHref: `/publications/${entry.id}`
}));

const groupedPublications = Array.from(
  publicationEntries.reduce((groups, entry) => {
    const year = entry.data.year;

    if (!groups.has(year)) {
      groups.set(year, []);
    }

    groups.get(year)!.push({
      ...entry.data,
      detailHref: `/publications/${entry.id}`
    });

    return groups;
  }, new Map<string, typeof publications>())
);
---

<MainLayout
  title={sectionsByKey.publications.pageTitle}
  description={sectionsByKey.publications.pageDescription}
>
  <PageHero
    eyebrow={publicationsPageHero.eyebrow}
    title={publicationsPageHero.title}
    description={publicationsPageHero.description}
    themeClass="page-hero-publications"
  />
  <section class="content-section">
    <SectionIntro
      eyebrow={publicationsSectionIntro.eyebrow}
      title={publicationsSectionIntro.title}
      description={publicationsSectionIntro.description}
    />
    <div class="section-actions">
      <a class="button button-secondary" href={withBase("/research#research-publications")}>
        {publicationsPageActionLabel}
      </a>
    </div>
    <div class="publication-archive">
      {
        groupedPublications.map(([year, items]) => (
          <section class="publication-year-group">
            <div class="publication-year-head">
              <span class="card-tag">{items.length} 篇</span>
              <h3>{year}</h3>
            </div>
            <PublicationCards items={items} />
          </section>
        ))
      }
    </div>
    </section>
</MainLayout>
