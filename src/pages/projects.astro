---
import MainLayout from "../layouts/MainLayout.astro";
import ProjectsShowcaseSection from "../components/ProjectsShowcaseSection.astro";
import PageHero from "../components/PageHero.astro";
import {
  projectCards,
  projectsPageHero,
  projectsSectionActions,
  projectsSectionIntro,
  projectsShowcase
} from "../data/projects";
import { sectionsByKey } from "../data/sections";
import { getRapidAIProjects } from "../utils/github";

const resolvedProjects = await getRapidAIProjects(projectCards);
---

<MainLayout
  title={sectionsByKey.projects.pageTitle}
  description={sectionsByKey.projects.pageDescription}
>
  <PageHero
    eyebrow={projectsPageHero.eyebrow}
    title={projectsPageHero.title}
    description={projectsPageHero.description}
    themeClass="page-hero-projects"
    panel={projectsPageHero.panel}
    hideEyebrow
  />

  <ProjectsShowcaseSection
    projects={resolvedProjects}
    limit={projectsShowcase.pageLimit}
    eyebrow={projectsSectionIntro.eyebrow}
    title={projectsSectionIntro.title}
    description={projectsSectionIntro.description}
    actions={[projectsSectionActions.browseAll]}
    hideEyebrow
  />
</MainLayout>
