---
import MainLayout from "../layouts/MainLayout.astro";
import SectionIntro from "../components/SectionIntro.astro";
import {
  publications,
  researchCommitteeRules,
  researchHighlights,
  researchHero,
  researchLeadership,
  researchOverviewCards,
  researchRecruitment
} from "../data/research";
import { withBase } from "../utils/base";
---

<MainLayout
  title="研究院 | RapidAI"
  description="RapidAI 研究院是 RapidAI 开源组织下属的学术研究机构，围绕论文指导、研究协作与工程转化持续建设。"
>
  <section class="page-hero page-hero-research">
    <div>
      <p class="eyebrow">{researchHero.eyebrow}</p>
      <h1>{researchHero.title}</h1>
      <p>{researchHero.description}</p>
    </div>
    <div class="page-hero-panel page-hero-panel-research">
      <span>{researchHero.panelTag}</span>
      <strong>{researchHero.panelTitle}</strong>
      <p>{researchHero.panelDescription}</p>
    </div>
  </section>

  <section class="content-section">
    <SectionIntro
      eyebrow="概述"
      title="研究院是组织内的学术延伸。"
      description="它不是独立于工程之外的展示页，而是围绕论文指导、算力资源、长期学术身份与工程转化能力搭建的研究协作模块。"
    />
    <div class="card-grid">
      {
        researchOverviewCards.map((card) => (
          <article class="card">
            <span class="card-tag">{card.tag}</span>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="content-section content-band">
    <div class="research-grid">
      <article class="research-feature">
        <p class="eyebrow">{researchRecruitment.eyebrow}</p>
        <h2>{researchRecruitment.title}</h2>
        <p>{researchRecruitment.description}</p>
        <div class="hero-actions">
          <a class="button button-primary" href={researchRecruitment.primaryAction.href}>
            {researchRecruitment.primaryAction.label}
          </a>
          <a
            class="button button-secondary"
            href={researchRecruitment.secondaryAction.href}
            target="_blank"
            rel="noreferrer"
          >
            {researchRecruitment.secondaryAction.label}
          </a>
        </div>
        <p class="research-note">联系邮箱：{researchRecruitment.email}</p>
      </article>

      <div class="research-sidecards">
        {
          researchHighlights.map((item) => (
            <article class:list={["signal-card", item.accent && "signal-card-accent"]}>
              <span>{item.tag}</span>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionIntro
      eyebrow="组织结构"
      title="管理团队与学术委员会"
      description="以下信息根据原始研究院概述页整理，当前站点以官网展示为主，后续可继续抽成独立数据源维护。"
    />
    <div class="card-grid">
      <article class="card">
        <span class="card-tag">管理团队</span>
        <h3>当前公布信息</h3>
        <ul class="research-list">
          {researchLeadership.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card">
        <span class="card-tag">学术委员会</span>
        <h3>成员规则</h3>
        <ul class="research-list">
          {researchCommitteeRules.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card">
        <span class="card-tag">延伸入口</span>
        <h3>后续可继续扩展</h3>
        <p>研究院信息和论文列表现已拆到独立数据文件。后续补团队、规则、消息、招生流程或论文条目，直接维护 `src/data/research.ts` 即可。</p>
        <div class="card-meta">
          <span>{publications.length} 条成果</span>
          <a class="card-link" href="#research-publications">查看论文列表</a>
        </div>
      </article>
    </div>
  </section>

  <section class="content-section" id="research-publications">
    <SectionIntro
      eyebrow="论文与成果"
      title="研究院论文与成果"
      description="论文、预印本、技术报告和有代表性的研究成果统一收纳在研究院页面内，便于持续维护和集中展示。"
    />
    <div class="timeline">
      {
        publications.map((item) => (
          <article class="timeline-item">
            <div>
              <span class="timeline-label">{item.year}</span>
            </div>
            <div class="card publication-card">
              <div class="publication-meta">
                <span class="card-tag">{item.type}</span>
                <span class="publication-venue">{item.venue}</span>
              </div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <div class="card-meta">
                <span>数据文件维护</span>
                <a class="card-link" href={item.href} target="_blank" rel="noreferrer">
                  查看来源
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</MainLayout>
