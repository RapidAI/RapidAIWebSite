---
import { getCollection } from "astro:content";
import ContentCardGrid from "../components/ContentCardGrid.astro";
import DetailListCardGrid from "../components/DetailListCardGrid.astro";
import PageHero from "../components/PageHero.astro";
import PublicationCards from "../components/PublicationCards.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SignalCardGrid from "../components/SignalCardGrid.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { publicationSection, publicationsPreviewLimit } from "../data/publications";
import { sectionsByKey } from "../data/sections";
import {
  researchHero,
  researchHighlights,
  researchOverviewCards,
  researchRecruitment,
  researchSections,
  researchStructureCards
} from "../data/research";
import { orderContentEntriesByFile } from "../utils/content-order";
import { withBase } from "../utils/base";

const publicationEntries = orderContentEntriesByFile(await getCollection("publications"));
const publications = publicationEntries.map((entry) => ({
  ...entry.data,
  detailHref: `/publications/${entry.id}`
}));
const visiblePublications = publications.slice(0, publicationsPreviewLimit);
---

<MainLayout
  title={sectionsByKey.research.pageTitle}
  description={sectionsByKey.research.pageDescription}
>
  <PageHero
    eyebrow={researchHero.eyebrow}
    title={researchHero.title}
    description={researchHero.description}
    themeClass="page-hero-research"
    panel={{
      tag: researchHero.panelTag,
      title: researchHero.panelTitle,
      description: researchHero.panelDescription
    }}
  />

  <section class="content-section">
    <SectionIntro
      eyebrow={researchSections.overview.eyebrow}
      title={researchSections.overview.title}
      description={researchSections.overview.description}
    />
    <ContentCardGrid items={researchOverviewCards} />
  </section>

  <section class="content-section content-band">
    <div class="research-grid">
      <article class="research-feature">
        <p class="eyebrow">{researchRecruitment.eyebrow}</p>
        <h2>{researchRecruitment.title}</h2>
        <p>{researchRecruitment.description}</p>
        <div class="hero-actions research-actions">
          <a class="button button-secondary" href={researchRecruitment.primaryAction.href}>
            {researchRecruitment.primaryAction.label}
          </a>
          <a
            class="button button-secondary"
            href={researchRecruitment.secondaryAction.href}
            target="_blank"
            rel="noreferrer"
          >
            {researchRecruitment.secondaryAction.label}
          </a>
        </div>
        <div class="research-contact">
          <span class="research-contact-eyebrow">联系邮箱</span>
          <a class="research-contact-value" href={researchRecruitment.primaryAction.href}>
            {researchRecruitment.email}
          </a>
        </div>
      </article>

      <SignalCardGrid items={researchHighlights} />
    </div>
  </section>

  <section class="content-section">
    <SectionIntro
      eyebrow={researchSections.structure.eyebrow}
      title={researchSections.structure.title}
      description={researchSections.structure.description}
    />
    <DetailListCardGrid
      items={researchStructureCards.map((card) =>
        card.href ? { ...card, meta: `${publications.length} 条论文记录` } : card
      )}
    />
  </section>

  <section class="content-section" id="research-publications">
    <SectionIntro
      eyebrow={publicationSection.eyebrow}
      title={publicationSection.title}
      description={publicationSection.description}
    />
    <PublicationCards items={visiblePublications} />
    {
      publications.length > publicationsPreviewLimit && (
        <div class="section-actions">
          <a class="button button-secondary" href={withBase("/publications")}>
            查看全部论文
          </a>
        </div>
      )
    }
  </section>
</MainLayout>
