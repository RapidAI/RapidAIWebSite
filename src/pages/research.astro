---
import PageHero from "../components/PageHero.astro";
import PublicationCards from "../components/PublicationCards.astro";
import SectionIntro from "../components/SectionIntro.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { publicationSection, publications } from "../data/publications";
import {
  researchCommitteeRules,
  researchHighlights,
  researchHero,
  researchLeadership,
  researchOverviewCards,
  researchRecruitment,
  researchSections
} from "../data/research";
---

<MainLayout
  title="研究院 | RapidAI"
  description="RapidAI 研究院是 RapidAI 开源组织下属的学术研究机构，围绕论文指导、研究协作与工程转化持续建设。"
>
  <PageHero
    eyebrow={researchHero.eyebrow}
    title={researchHero.title}
    description={researchHero.description}
    themeClass="page-hero-research"
    panel={{
      tag: researchHero.panelTag,
      title: researchHero.panelTitle,
      description: researchHero.panelDescription
    }}
  />

  <section class="content-section">
    <SectionIntro
      eyebrow={researchSections.overview.eyebrow}
      title={researchSections.overview.title}
      description={researchSections.overview.description}
    />
    <div class="card-grid">
      {
        researchOverviewCards.map((card) => (
          <article class="card">
            <span class="card-tag">{card.tag}</span>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="content-section content-band">
    <div class="research-grid">
      <article class="research-feature">
        <p class="eyebrow">{researchRecruitment.eyebrow}</p>
        <h2>{researchRecruitment.title}</h2>
        <p>{researchRecruitment.description}</p>
        <div class="hero-actions">
          <a class="button button-primary" href={researchRecruitment.primaryAction.href}>
            {researchRecruitment.primaryAction.label}
          </a>
          <a
            class="button button-secondary"
            href={researchRecruitment.secondaryAction.href}
            target="_blank"
            rel="noreferrer"
          >
            {researchRecruitment.secondaryAction.label}
          </a>
        </div>
        <p class="research-note">联系邮箱：{researchRecruitment.email}</p>
      </article>

      <div class="research-sidecards">
        {
          researchHighlights.map((item) => (
            <article class:list={["signal-card", item.accent && "signal-card-accent"]}>
              <span>{item.tag}</span>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionIntro
      eyebrow={researchSections.structure.eyebrow}
      title={researchSections.structure.title}
      description={researchSections.structure.description}
    />
    <div class="card-grid">
      <article class="card">
        <span class="card-tag">管理团队</span>
        <h3>当前公开信息</h3>
        <ul class="research-list">
          {researchLeadership.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card">
        <span class="card-tag">学术委员会</span>
        <h3>成员规则</h3>
        <ul class="research-list">
          {researchCommitteeRules.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card">
        <span class="card-tag">维护说明</span>
        <h3>论文卡片和研究信息已经拆分</h3>
        <p>研究院页继续展示组织、招募和论文卡片。后续新增论文时，只需要维护 `src/data/publications.ts`。</p>
        <div class="card-meta">
          <span>{publications.length} 条论文记录</span>
          <a class="card-link" href="#research-publications">查看论文卡片</a>
        </div>
      </article>
    </div>
  </section>

  <section class="content-section" id="research-publications">
    <SectionIntro
      eyebrow={publicationSection.eyebrow}
      title={publicationSection.title}
      description={publicationSection.description}
    />
    <PublicationCards items={publications} />
  </section>
</MainLayout>
