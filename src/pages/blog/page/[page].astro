---
import { getCollection } from "astro:content";
import BlogList from "../../../components/BlogList.astro";
import PageHero from "../../../components/PageHero.astro";
import Pagination from "../../../components/Pagination.astro";
import SectionIntro from "../../../components/SectionIntro.astro";
import MainLayout from "../../../layouts/MainLayout.astro";
import { blogPageHero, blogSections } from "../../../data/blog";
import { sectionsByKey } from "../../../data/sections";
import { orderContentEntriesByFile } from "../../../utils/content-order";

export async function getStaticPaths() {
  const pageSize = 6;
  const posts = orderContentEntriesByFile(await getCollection("blog"));
  const totalPages = Math.ceil(posts.length / pageSize);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const currentPage = index + 2;
    const start = (currentPage - 1) * pageSize;
    const end = start + pageSize;

    return {
      params: { page: String(currentPage) },
      props: {
        posts: posts.slice(start, end),
        currentPage,
        totalPages
      }
    };
  });
}

const { posts, currentPage, totalPages } = Astro.props;
---

<MainLayout
  title={`博客第 ${currentPage} 页 | RapidAI`}
  description={sectionsByKey.blog.pageDescription}
>
  <PageHero
    eyebrow={blogPageHero.eyebrow}
    title={blogPageHero.title}
    description={blogPageHero.description}
    themeClass="page-hero-blog"
    panel={blogPageHero.panel}
  />

  <section class="content-section">
    <SectionIntro
      eyebrow={blogSections.paged.eyebrow}
      title={blogSections.paged.title}
      description={blogSections.paged.description}
    />
    <BlogList posts={posts} />
    <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/blog" />
  </section>
</MainLayout>
