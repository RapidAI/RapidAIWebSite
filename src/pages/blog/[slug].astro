---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { withBase } from "../../utils/base";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<MainLayout title={`${post.data.title} | RapidAI`} description={post.data.description}>
  <section class="page-hero markdown-page">
    <div>
      <p class="eyebrow">社区博客</p>
      <h1>{post.data.title}</h1>
      <div class="blog-detail-meta">
        <span class="timeline-label">{post.data.date.toISOString().slice(0, 10)}</span>
        <span class="blog-author">@{post.data.author}</span>
      </div>
      <div class="chip-row">
        {post.data.tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    </div>
  </section>

  <section class="content-section markdown-page">
    <div class="blog-detail-cover">
      <img src={withBase(post.data.cover)} alt={post.data.title} />
    </div>
    <Content />
  </section>
</MainLayout>
