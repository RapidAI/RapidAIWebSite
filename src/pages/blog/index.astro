---
import { getCollection } from "astro:content";
import BlogList from "../../components/BlogList.astro";
import PageHero from "../../components/PageHero.astro";
import Pagination from "../../components/Pagination.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import { blogPageHero, blogSections } from "../../data/blog";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const pageSize = 6;
const currentPage = 1;
const totalPages = Math.max(1, Math.ceil(posts.length / pageSize));
const visiblePosts = posts.slice(0, pageSize);
---

<MainLayout title="博客 | RapidAI" description="RapidAI 博客与社区内容。">
  <PageHero
    eyebrow={blogPageHero.eyebrow}
    title={blogPageHero.title}
    description={blogPageHero.description}
    themeClass="page-hero-blog"
    panel={blogPageHero.panel}
  />

  <section class="content-section">
    <SectionIntro
      eyebrow={blogSections.latest.eyebrow}
      title={blogSections.latest.title}
      description={blogSections.latest.description}
    />
    <BlogList posts={visiblePosts} />
    <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/blog" />
  </section>
</MainLayout>
