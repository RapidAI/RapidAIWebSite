---
import { getCollection } from "astro:content";
import ExploreLinksSection from "../components/ExploreLinksSection.astro";
import Hero from "../components/Hero.astro";
import ProjectsShowcaseSection from "../components/ProjectsShowcaseSection.astro";
import SectionIntro from "../components/SectionIntro.astro";
import SignalBandSection from "../components/SignalBandSection.astro";
import StatsSection from "../components/StatsSection.astro";
import { homeExploreCards, homeHero, homeSections, homeSignals, homeStats } from "../data/home";
import {
  projectCards,
  projectsSectionActions,
  projectsSectionIntro,
  projectsShowcase
} from "../data/projects";
import MainLayout from "../layouts/MainLayout.astro";
import { getRapidAIProjects } from "../utils/github";
import { withBase } from "../utils/base";

const blogPosts = await getCollection("blog");
const resolvedProjects = await getRapidAIProjects(projectCards);
---

<MainLayout
  title="RapidAI | AI 工程化开源组织"
  description="RapidAI 专注于 AI 工程化落地，构建从研究到部署之间的桥梁。"
>
  <Hero hero={homeHero} />

  <StatsSection intro={homeSections.positioning} items={homeStats} />

  <SignalBandSection copy={homeSections.signal} items={homeSignals} />

  <section class="content-section">
    <SectionIntro
      eyebrow={homeSections.research.eyebrow}
      title={homeSections.research.title}
      description={homeSections.research.description}
    />
    <div class="section-actions">
      <a class="button button-secondary" href={withBase(homeSections.research.action.href)}>
        {homeSections.research.action.label}
      </a>
    </div>
  </section>

  <ProjectsShowcaseSection
    projects={resolvedProjects}
    limit={projectsShowcase.homeLimit}
    eyebrow={projectsSectionIntro.eyebrow}
    title={projectsSectionIntro.title}
    description={projectsSectionIntro.description}
    actions={[projectsSectionActions.openProjectsPage, projectsSectionActions.browseAll]}
  />

  <ExploreLinksSection
    intro={homeSections.explore}
    cards={homeExploreCards}
    blogCount={blogPosts.length}
  />
</MainLayout>
